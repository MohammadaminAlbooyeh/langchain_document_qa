# ===== APPLICATION SETTINGS =====
APP_ENV=development
APP_NAME=LangChain Document QA
DEBUG=true
LOG_LEVEL=INFO
API_PORT=8000
API_HOST=0.0.0.0
API_KEY_PREFIX=sk_

# ===== DATABASE =====
DATABASE_URL=sqlite:///./data/langchain_qa.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/langchain_qa
DATABASE_POOL_SIZE=5
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# ===== SECURITY =====
SECRET_KEY=your-super-secret-key-minimum-32-characters-long-please-change-me
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ALLOWED_HOSTS=localhost,127.0.0.1
MAX_UPLOAD_SIZE=100

# ===== LLM PROVIDERS =====
DEFAULT_LLM=openai
OPENAI_API_KEY=sk-proj-...your-openai-key-here...
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here...
COHERE_API_KEY=...your-cohere-key-here...

# ===== LLM MODELS =====
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.0
MAX_TOKENS=4096

# ===== VECTOR STORE =====
VECTOR_STORE_TYPE=chroma
CHROMA_DB_PATH=./chroma_db
# For Pinecone:
# VECTOR_STORE_TYPE=pinecone
# PINECONE_API_KEY=...your-pinecone-key...
# PINECONE_ENVIRONMENT=us-east-1-aws
# PINECONE_INDEX_NAME=langchain-qa

# ===== TEXT PROCESSING =====
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNK_STRATEGY=token

# ===== CACHING =====
CACHE_TYPE=memory
# For Redis: CACHE_TYPE=redis
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL=600

# ===== RATE LIMITING =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ===== MONITORING & LOGGING =====
LOG_TO_FILE=
PROMETHEUS_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== OPTIONAL: EMAIL =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@yourdomain.com

# ===== OPTIONAL: SECURITY HEADERS =====
# SECURE_BROWSER_XSS_FILTER=true
# SECURE_CONTENT_SECURITY_POLICY=true
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=true

# ===== OPTIONAL: DEVELOPMENT =====
# MOCK_LLM=false
# MOCK_EMBEDDINGS=false
# SKIP_DB_INIT=false
